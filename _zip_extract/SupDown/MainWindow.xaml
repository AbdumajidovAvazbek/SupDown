<Window x:Class="SupDown.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SupDown — YouTube Subtitle Downloader"
        Height="520" Width="720"
        MinHeight="520" MinWidth="620"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#585B70"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="#CDD6F4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                <TextBlock x:Name="Placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#6C7086"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           Margin="{TemplateBinding Padding}"
                                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B4D0FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#6C7086"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#585B70"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6C7086"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="SupDown" FontSize="24" FontFamily="Segoe UI Bold"
                       Foreground="#89B4FA" FontWeight="Bold"/>
            <TextBlock Text="YouTube subtitrlari yuklovchi" FontSize="12"
                       Foreground="#6C7086" FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- YouTube URL -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock Text="YouTube havola" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="UrlTextBox"
                     Style="{StaticResource TextBoxStyle}"
                     Tag="https://www.youtube.com/watch?v=..."
                     Height="36"/>
        </StackPanel>

        <!-- Output folder -->
        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock Text="Saqlash papkasi" Style="{StaticResource LabelStyle}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FolderTextBox"
                         Grid.Column="0"
                         Style="{StaticResource TextBoxStyle}"
                         IsReadOnly="True"
                         Tag="Papka tanlanmagan..."
                         Height="36"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="1"
                        Style="{StaticResource SecondaryButton}"
                        Content="Tanlash"
                        Width="80" Height="36"
                        Click="BrowseFolder_Click"/>
            </Grid>
        </StackPanel>

        <!-- Cookies file -->
        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Style="{StaticResource LabelStyle}">
                <Run Text="cookies.txt fayli"/>
                <Run Text=" (YouTube rate limit xatosini hal qiladi)" Foreground="#6C7086"/>
            </TextBlock>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="CookiesTextBox"
                         Grid.Column="0"
                         Style="{StaticResource TextBoxStyle}"
                         IsReadOnly="True"
                         Tag="Ixtiyoriy — cookies.txt fayl yo'li..."
                         Height="36"
                         Margin="0,0,8,0"/>
                <Button Grid.Column="1"
                        Style="{StaticResource SecondaryButton}"
                        Content="Tanlash"
                        Width="80" Height="36"
                        Click="BrowseCookies_Click"/>
            </Grid>
        </StackPanel>

        <!-- Language -->
        <StackPanel Grid.Row="4" Margin="0,0,0,20">
            <TextBlock Text="Subtitl tili (ixtiyoriy, masalan: en, uz, ru)" Style="{StaticResource LabelStyle}"/>
            <TextBox x:Name="LangTextBox"
                     Style="{StaticResource TextBoxStyle}"
                     Tag="Bo'sh qoldiring — avtomatik birinchi topilgan til"
                     Height="36"/>
        </StackPanel>

        <!-- Download + Copy buttons -->
        <Grid Grid.Row="5" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    x:Name="DownloadBtn"
                    Style="{StaticResource PrimaryButton}"
                    Content="Subtitlni yuklab olish"
                    Height="42"
                    Click="Download_Click"/>
            <Button Grid.Column="2"
                    x:Name="CopyBtn"
                    Style="{StaticResource SecondaryButton}"
                    Content="Matnni nusxalash"
                    Height="42"
                    Width="160"
                    IsEnabled="False"
                    Click="CopyText_Click"/>
        </Grid>

        <!-- Log / Status -->
        <Border Grid.Row="6"
                Background="#313244"
                CornerRadius="8"
                BorderBrush="#585B70"
                BorderThickness="1"
                Padding="12">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="LogBox"
                         Background="Transparent"
                         Foreground="#A6E3A1"
                         BorderThickness="0"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="12"
                         Text="Tayyor. Havola va papka kiriting, so'ng 'Yuklab olish' tugmasini bosing."
                         AcceptsReturn="True"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
